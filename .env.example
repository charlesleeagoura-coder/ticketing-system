# Copy this file to .env and fill in your values
PORT=3000

# Email Configuration (SMTP)
# Leave blank to log emails to console instead of sending
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Support Desk <your-email@gmail.com>"

# Database path (default: tickets.db in project root)
# DB_PATH=./tickets.db
